# research-library — copy to ".env" in this directory and fill in.
#   cp .env.example .env

# Required for ADS search, BibTeX, pdf2ads, ads-data-products, etc.
# Get token: https://ui.adsabs.harvard.edu/user/settings/token
ADS_API_TOKEN=

# Optional: override default ~/program-data path (see config.py)
# RESEARCH_LIBRARY_DATA_DIR=

# MiniMax（pdf-analyze；与 quantitative_finance 一致：仅 OpenAI 兼容
# POST https://api.minimax.chat/v1/chat/completions）
# 可用与 QF 相同优先级：`QF_LLM_API_KEY` → `MINIMAX_API_KEY`，
# `QF_LLM_BASE_URL` → `MINIMAX_BASE_URL`，`QF_LLM_MODEL` → `MINIMAX_MODEL`
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.7-highspeed
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# 勿填 api.minimax.io/.../chatcompletion_v2（除非刻意走 native，QF 不用该端点）
# MINIMAX_GROUP_ID=
# MINIMAX_API_STYLE=openai
# --- 与 quantitative_finance 一致：优先读 QF_LLM_PROVIDER；无需再配 RESEARCH_LLM_PROVIDER ---
# QF_LLM_PROVIDER=minimax   # 或 openai / openai_compat（chat 走 QF_LLM_API_KEY + BASE + MODEL）
# QF_LLM_API_KEY=
# QF_LLM_BASE_URL=https://api.openai.com/v1
# QF_LLM_MODEL=gpt-4o-mini
# 仅本仓库临时覆盖 provider 时（可选）：
# RESEARCH_LLM_PROVIDER=

# 每次 MiniMax 调用后向 stderr 打印 usage（1 / true / yes / stderr）
# RESEARCH_LLM_LOG_USAGE=1
# HTTP 超时秒数（长 PDF + 高 max_tokens 时建议 ≥600；不设则默认 600）
# RESEARCH_LLM_TIMEOUT=600

# ADS / arXiv HTTP 重试（429/5xx 指数退避）
# RESEARCH_HTTP_RETRY_ATTEMPTS=3
# RESEARCH_HTTP_RETRY_BASE_DELAY=0.8

# Logging：RESEARCH_LOG_LEVEL=DEBUG/INFO/WARNING；RESEARCH_LOG_FORMAT=text|json
# RESEARCH_LOG_LEVEL=INFO
# RESEARCH_LOG_FORMAT=text

# LLM 单次补全上限（MiniMax 推理模型会先占用大量 token；压测可调更高）
# RESEARCH_LLM_MAX_COMPLETION_TOKENS=32768
# 正文作者–年份与参考文献列表匹配时，最多跟几条（与模型输出合并）
# RESEARCH_PDF_CHAIN_BODY_MATCH_MAX=8

# 引用链：每步 JSON / 最终报告（未设时分别回退到上一项与 65536）
# RESEARCH_PDF_CHAIN_MAX_STEP_TOKENS=
# RESEARCH_PDF_CHAIN_MAX_SYNTH_TOKENS=
# 引用链：降低单次请求体量 — 语义检索并入 prompt 的字符/块数上限（默认 16000 / 10）
# RESEARCH_PDF_CHAIN_RETRIEVAL_MAX_CHARS=16000
# RESEARCH_PDF_CHAIN_RETRIEVAL_MAX_CHUNKS=10
# 引用链：每跳送入 LLM 的正文硬上限（默认 18000，head+tail 截断）
# RESEARCH_PDF_CHAIN_STEP_BODY_MAX_CHARS=18000
# 引用链：分段调用（1=先跟文献编号、再单独要摘录；降低单条 completion 压力；默认开启）
# RESEARCH_PDF_CHAIN_STEP_SPLIT=1
# RESEARCH_PDF_CHAIN_STEP_PASS1_BODY_CHARS=10000
# 引用链：两步 LLM 时第一步（跟读 ref）completion 上限；推理类模型宜 ≥8k（默认 16k）
# RESEARCH_PDF_CHAIN_STEP_PASS1_MAX_TOKENS=16384
# RESEARCH_PDF_CHAIN_STEP_PASS2_MAX_TOKENS=0
#   （0 = 与 RESEARCH_PDF_CHAIN_MAX_STEP_TOKENS 相同）
# 引用链：作者–年份 haystack 用的正文最大字符（默认 120000，防全文过长拖慢匹配）
# RESEARCH_PDF_CHAIN_MATCH_BODY_MAX_CHARS=120000
# 引用链：最终报告 trace 打包 — 单节点 JSON 截断 / 单包最大字符；超限则 map-reduce 多轮合成
# RESEARCH_PDF_CHAIN_SYNTH_NODE_MAX_CHARS=8000
# RESEARCH_PDF_CHAIN_SYNTH_BUNDLE_MAX_CHARS=40000
# RESEARCH_PDF_CHAIN_SYNTH_PARTIAL_MAX_TOKENS=6144

# Max characters of PDF text sent to the LLM (truncate middle if exceeded)
# RESEARCH_PDF_ANALYZE_MAX_CHARS=100000

# Semantic index
# RESEARCH_SEMANTIC_BACKEND=vector | fts
#   vector — Chroma + embedding API（pip install -e ".[semantic]" + RESEARCH_EMBEDDING_*）
#   fts    — 仅 SQLite FTS5 检索 PDF 分块，无需 Chroma/嵌入 API（仍要 pdfminer 抽字）
# 未设 RESEARCH_EMBEDDING_PROVIDER 时：QF_LLM_PROVIDER=openai → openai_compat + QF_LLM_*；否则 minimax
# RESEARCH_EMBEDDING_PROVIDER=minimax | openai_compat | local_sentence_transformer
# MiniMax：与 chat 相同 KEY / BASE（QF_LLM_* / MINIMAX_*）；嵌入默认模型 embo-01
# RESEARCH_EMBEDDING_MODEL=embo-01
# MINIMAX_EMBEDDING_MODEL=
# RESEARCH_EMBEDDING_MINIMAX_TYPE=db
# openai_compat：QF_LLM_API_KEY / QF_LLM_BASE_URL（与 QF 一致）；可选 RESEARCH_OPENAI_* 覆盖
# RESEARCH_SEMANTIC_CHUNK_SIZE=1200
# RESEARCH_SEMANTIC_CHUNK_OVERLAP=200
# RESEARCH_SEMANTIC_EMBED_BATCH=16
# 切窗时优先在段落/句号边界对齐（1=默认；0=回退到纯字符滑窗）
# RESEARCH_SEMANTIC_CHUNK_BOUNDARY=1
# 单 paper 召回：同时跑 FTS + 向量并用 RRF 融合（1=默认；0=单后端）
# RESEARCH_SEMANTIC_HYBRID=1
# 在召回结果上做 MMR 多样化（1=默认）
# RESEARCH_SEMANTIC_MMR=1
# 给每段召回内容加 [chunk_id=N] 前缀，便于 LLM 报告里引用回原文
# RESEARCH_GROUNDING_MARKERS=1
# OpenAI-兼容嵌入：query / document 时附加 input_type（视服务商而定）
# RESEARCH_EMBEDDING_QUERY_INPUT_TYPE=
# RESEARCH_EMBEDDING_DOC_INPUT_TYPE=
# library_compare_topic 单次 JSON 补全上限
# RESEARCH_SEMANTIC_COMPARE_MAX_TOKENS=8192
# topic-dossier / library_topic_dossier 长文合成上限
# RESEARCH_TOPIC_DOSSIER_MAX_TOKENS=8192
#
# 引用链：优先使用 library 中已同步的 paper_references（ADS）；设为 0 则始终解析 PDF 参考文献表
# RESEARCH_PDF_CHAIN_LIBRARY_REFS=1
# 引用链 library 模式：根 PDF 不在库时自动 ingest（需 ADS token）；设为 0 关闭
# RESEARCH_PDF_CHAIN_AUTO_INGEST=1
# library ingest-pdf / library_ingest_pdf：无 DOI/arXiv 时不做标题匹配（仅强标识）
# RESEARCH_PDF_INGEST_REQUIRE_STRONG_ID=1
# PDF ingest: skip writing paper_references from ADS (default is to sync)
# RESEARCH_PDF_INGEST_SYNC_REFERENCES=0
#
# 引用链：合并 ref_classifier 式 METHOD 窗口提示（与 model / citation_match 取并集）
# RESEARCH_PDF_CHAIN_METHOD_HINTS=1
# RESEARCH_PDF_CHAIN_METHOD_HINTS_MAX=24
#
# 引用链：参考文献表过长时只对 LLM 展示子集（仍用全文做 citation_match / ingest）
# RESEARCH_PDF_CHAIN_REF_NARROW_ABOVE=60
# RESEARCH_PDF_CHAIN_REF_PROMPT_MAX=80
# RESEARCH_PDF_CHAIN_REF_MUST_PICK=12
# 引用链：合并策略 — 0=loose(并集)；1=tight(模型 ∩ (citation∪method)，无 hint 时仅模型)
# RESEARCH_PDF_CHAIN_TIGHT=0
# 引用链：每跳最多跟几条（0=不限制）
# RESEARCH_PDF_CHAIN_MAX_FOLLOW_PER_HOP=0
# 引用链：整条链的 token 预算上限；超过即停在当前跳（0=不限制）
# RESEARCH_PDF_CHAIN_TOTAL_TOKEN_BUDGET=0
# 引用链：每跳并发解析 + 下载子 PDF 的线程数（默认 4）
# RESEARCH_PDF_CHAIN_ACQUIRE_WORKERS=4
# 引用链：sync_references_from_ads 的重试与每次调用间隔（毫秒）
# RESEARCH_PDF_CHAIN_SYNC_RETRY_ATTEMPTS=3
# RESEARCH_PDF_CHAIN_SYNC_SLEEP_MS=500
# 引用链：对 LLM 摘录做 grounding 校验（不在文本里就丢掉；1=开启，默认）
# RESEARCH_PDF_CHAIN_VERIFY_EXCERPTS=1
# 引用链：子文献 ingest 后若无 chunks 则自动 semantic.index_paper（ar5iv→本地TeX→PDF）
# RESEARCH_PDF_CHAIN_AUTO_SEMANTIC_INDEX=0
# PDF 入库（ingest-pdf）后自动 semantic-index，同样走 TeX→PDF fallback
# RESEARCH_INGEST_AUTO_SEMANTIC_INDEX=1
# semantic-index 前无缓存 TeX 时自动 fetch（ar5iv → 本地 tarball → PDF）
# RESEARCH_SEMANTIC_AUTO_FETCH_TEX=1
# arXiv tarball 本地清洗后端（pylatexenc | pandoc | latexml）
# RESEARCH_TEX_LOCAL_BACKEND=pylatexenc
# ar5iv 请求间隔秒数（默认 1）
# RESEARCH_AR5IV_SLEEP_SECONDS=1
# 引用链 / reference_acquire：单篇 PDF 下载超时秒数（curl --max-time，默认 120）
# RESEARCH_PDF_ACQUIRE_TIMEOUT=120
#
# --- 本地 Qwen / SentenceTransformers 嵌入（需 pip install -e ".[semantic,semantic-local]"）---
# 指向含 .cache/huggingface 的「qwen」项目根目录（与该项目 embed.py 的 HF_HOME 一致）
# RESEARCH_LOCAL_EMBEDDING_HOME=/Users/you/program/qwen
# 或直接指定 Hugging Face 缓存根目录（等同于 HF_HOME）
# RESEARCH_LOCAL_EMBEDDING_HF_HOME=
# RESEARCH_LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# RESEARCH_LOCAL_EMBEDDING_DEVICE=cuda   # 或 cpu / mps
# Qwen3 检索：查询侧 prompt（文档侧默认不传 prompt_name，可设为 document）
# RESEARCH_LOCAL_EMBEDDING_PROMPT_QUERY=query
# RESEARCH_LOCAL_EMBEDDING_PROMPT_DOCUMENT=
# 仅使用本地 hub 缓存、不访问 huggingface.co（模型已在 qwen/.cache 时建议开启）
# RESEARCH_LOCAL_EMBEDDING_HF_OFFLINE=1
# 部分 HF 模型需 trust_remote_code（1/true/yes）
# RESEARCH_LOCAL_EMBEDDING_TRUST_REMOTE_CODE=1
# 写入 Chroma 前 L2 归一化（1/true/yes，可选，有利于 cosine）
# RESEARCH_LOCAL_EMBEDDING_NORMALIZE=
